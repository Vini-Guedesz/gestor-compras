# ================================================================================
# VARIÁVEIS DE AMBIENTE - GESTOR DE COMPRAS FRONTEND (EXEMPLO)
# ================================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário
# ================================================================================

# ====================
# API CONFIGURATION
# ====================
# URL base da API backend
VITE_API_BASE_URL=http://localhost:8081

# ====================
# APPLICATION CONFIGURATION
# ====================
VITE_APP_NAME=Gestor de Compras
VITE_APP_VERSION=2.0.0
VITE_APP_ENV=development

# ====================
# FEATURE FLAGS
# ====================
VITE_ENABLE_DEBUG=true
VITE_ENABLE_VERBOSE_LOGGING=false

# ====================
# TIMEOUT CONFIGURATION
# ====================
VITE_API_TIMEOUT=10000
VITE_REPORT_TIMEOUT=30000

# ====================
# UI CONFIGURATION
# ====================
VITE_TOAST_DURATION=5000
VITE_DEFAULT_PAGE_SIZE=20
