# Variáveis de Ambiente - Gestor de Compras Backend
# Copie este arquivo para .env e preencha com valores reais

# JWT Secret Key (OBRIGATÓRIO em produção)
# Gere um secret seguro com: openssl rand -base64 64
JWT_SECRET=your-super-secure-secret-key-here-minimum-256-bits

# Database Configuration (opcional, sobrescreve application.properties)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/gestorcomprasbackend
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=admin

# Server Port (opcional)
# SERVER_PORT=8081

# Spring Profile (dev, prod)
# SPRING_PROFILES_ACTIVE=dev

# CORS Allowed Origins (opcional)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
