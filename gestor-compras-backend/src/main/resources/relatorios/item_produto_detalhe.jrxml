    <parameter name="ID_ITEM" class="java.lang.Long"/>

    <queryString>
        <![CDATA[SELECT ip.id, ip.nome, ip.quantidade, ip.descricao, ip.observacao, sp.id as solicitacao_id
                 FROM item_pedido ip
                 LEFT JOIN solicitacao_de_pedido sp ON ip.solicitacao_de_pedido_id = sp.id
                 WHERE ip.id = $P{ID_ITEM}]]>
    </queryString>

    <field name="id" class="java.lang.Long"/>
    <field name="nome" class="java.lang.String"/>
    <field name="quantidade" class="java.lang.Integer"/>
    <field name="descricao" class="java.lang.String"/>
    <field name="observacao" class="java.lang.String"/>
    <field name="solicitacaoDePedido" class="com.gestordecompras.gestorcomprasbackend.model.pedido.SolicitacaoDePedido"/>

