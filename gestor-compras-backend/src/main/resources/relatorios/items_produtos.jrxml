              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="items_produtos" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">

    <!-- Estilos padronizados -->
    <style name="Title" forecolor="#1A237E" fontName="Arial" fontSize="24" isBold="true"/>
    <style name="SubTitle" forecolor="#3F51B5" fontName="Arial" fontSize="14" isBold="true"/>
    <style name="Header" forecolor="#FFFFFF" fontName="Arial" fontSize="11" isBold="true"/>
    <style name="Detail" fontName="Arial" fontSize="10"/>
    <style name="Footer" forecolor="#666666" fontName="Arial" fontSize="9"/>
    <style name="Row" mode="Opaque">
        <conditionalStyle>
            <conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
            <style backcolor="#F5F5F5"/>
        </conditionalStyle>
    </style>

    <queryString>
        <![CDATA[SELECT id, nome, quantidade, solicitacao_de_pedido_id FROM item_pedido]]>
    </queryString>

    <field name="id" class="java.lang.Long"/>
    <field name="nome" class="java.lang.String"/>
    <field name="quantidade" class="java.lang.Integer"/>
    <field name="solicitacaoDePedido" class="com.gestordecompras.gestorcomprasbackend.model.pedido.SolicitacaoDePedido"/>

    <!-- Cabeçalho do Relatório -->
    <title>
        <band height="125">
            <!-- Logo UEMA Centralizada -->
            <image scaleImage="RetainShape" hAlign="Center" vAlign="Top">
                <reportElement x="192" y="10" width="150" height="50"/>
                <imageExpression><![CDATA["relatorios/logo-uema-site.png"]]></imageExpression>
            </image>

            <!-- Nome do Relatório Centralizado -->
            <staticText>
                <reportElement style="Title" x="0" y="70" width="535" height="35"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[RELATÓRIO DE ITENS DE PEDIDO]]></text>
            </staticText>

            <!-- Versão do Relatório -->
            <staticText>
                <reportElement style="Footer" x="420" y="108" width="115" height="12"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isItalic="true"/>
                </textElement>
                <text><![CDATA[Versão 1.0]]></text>
            </staticText>

            <!-- Linha Separadora -->
            <line>
                <reportElement x="0" y="122" width="535" height="1" forecolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="2.0" lineStyle="Solid"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <!-- Cabeçalho de Página -->
    <pageHeader>
        <band height="5">
            <line>
                <reportElement x="0" y="2" width="535" height="1" forecolor="#CCCCCC"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </line>
        </band>
    </pageHeader>

    <!-- Cabeçalho das Colunas -->
    <columnHeader>
        <band height="25">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="535" height="25" backcolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement style="Header" x="5" y="2" width="60" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[ID]]></text>
            </staticText>

            <staticText>
                <reportElement style="Header" x="70" y="2" width="240" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <paragraph leftIndent="5"/>
                </textElement>
                <text><![CDATA[Nome do Item]]></text>
            </staticText>

            <staticText>
                <reportElement style="Header" x="315" y="2" width="100" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Quantidade]]></text>
            </staticText>

            <staticText>
                <reportElement style="Header" x="420" y="2" width="110" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[ID Solicitação]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Detalhes (Linhas de Dados) -->
    <detail>
        <band height="25">
            <elementGroup>
                <rectangle>
                    <reportElement style="Row" x="0" y="0" width="535" height="25"/>
                    <graphicElement>
                        <pen lineWidth="0.5" lineColor="#E0E0E0"/>
                    </graphicElement>
                </rectangle>

                <textField textAdjust="StretchHeight">
                    <reportElement style="Detail" x="5" y="2" width="60" height="20"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
                </textField>

                <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                    <reportElement style="Detail" x="70" y="2" width="240" height="20"/>
                    <textElement textAlignment="Left" verticalAlignment="Middle">
                        <paragraph leftIndent="5"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{nome}]]></textFieldExpression>
                </textField>

                <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                    <reportElement style="Detail" x="315" y="2" width="100" height="20"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[$F{quantidade}]]></textFieldExpression>
                </textField>

                <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                    <reportElement style="Detail" x="420" y="2" width="110" height="20"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[$F{solicitacaoDePedido} != null ? $F{solicitacaoDePedido}.getId() : "N/A"]]></textFieldExpression>
                </textField>
            </elementGroup>
        </band>
    </detail>

    <!-- Rodapé da Página -->
