<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="itens_mais_solicitados" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">

    <style name="Title" forecolor="#1A237E" fontName="Arial" fontSize="24" isBold="true"/>
    <style name="Header" forecolor="#FFFFFF" fontName="Arial" fontSize="11" isBold="true"/>
    <style name="Detail" fontName="Arial" fontSize="10"/>
    <style name="Footer" forecolor="#666666" fontName="Arial" fontSize="9"/>
    <style name="Row" mode="Opaque">
        <conditionalStyle>
            <conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
            <style backcolor="#F5F5F5"/>
        </conditionalStyle>
    </style>

    <field name="nomeItem" class="java.lang.String"/>
    <field name="quantidadeTotal" class="java.lang.Long"/>
    <field name="numeroSolicitacoes" class="java.lang.Long"/>
    <field name="descricao" class="java.lang.String"/>

    <variable name="RANKING" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{nomeItem}]]></variableExpression>
    </variable>

    <title>
        <band height="125">
            <image scaleImage="RetainShape" hAlign="Center" vAlign="Top">
                <reportElement x="192" y="10" width="150" height="50"/>
                <imageExpression><![CDATA["relatorios/logo-uema-site.png"]]></imageExpression>
            </image>
            <staticText>
                <reportElement style="Title" x="0" y="70" width="535" height="35"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[ITENS MAIS SOLICITADOS]]></text>
            </staticText>
            <staticText>
                <reportElement style="Footer" x="420" y="108" width="115" height="12"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isItalic="true"/>
                </textElement>
                <text><![CDATA[Versão 1.0]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="122" width="535" height="1" forecolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="2.0"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="535" height="25" backcolor="#3F51B5"/>
            </rectangle>
            <staticText>
                <reportElement style="Header" x="5" y="2" width="40" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[#]]></text>
            </staticText>
            <staticText>
                <reportElement style="Header" x="50" y="2" width="200" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <paragraph leftIndent="5"/>
                </textElement>
                <text><![CDATA[Nome do Item]]></text>
            </staticText>
            <staticText>
                <reportElement style="Header" x="255" y="2" width="90" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Qtd. Total]]></text>
            </staticText>
            <staticText>
                <reportElement style="Header" x="350" y="2" width="90" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Nº Pedidos]]></text>
            </staticText>
            <staticText>
                <reportElement style="Header" x="445" y="2" width="85" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Média/Pedido]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="30">
            <rectangle>
                <reportElement style="Row" x="0" y="0" width="535" height="30"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#E0E0E0"/>
                </graphicElement>
            </rectangle>
            <textField>
                <reportElement style="Detail" x="5" y="5" width="40" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{RANKING}]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight">
                <reportElement style="Detail" x="50" y="5" width="200" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <paragraph leftIndent="5"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{nomeItem}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement style="Detail" x="255" y="5" width="90" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{quantidadeTotal}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement style="Detail" x="350" y="5" width="90" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{numeroSolicitacoes}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.0">
                <reportElement style="Detail" x="445" y="5" width="85" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{quantidadeTotal}.doubleValue() / $F{numeroSolicitacoes}.doubleValue()]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="30">
            <line>
                <reportElement x="0" y="2" width="535" height="1" forecolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="1.0"/>
                </graphicElement>
            </line>
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement style="Footer" x="5" y="8" width="150" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement style="Footer" x="180" y="8" width="180" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Sistema de Gestão de Compras - UEMA]]></text>
            </staticText>
            <textField>
                <reportElement style="Footer" x="385" y="8" width="100" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report">
                <reportElement style="Footer" x="485" y="8" width="50" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[" de " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>