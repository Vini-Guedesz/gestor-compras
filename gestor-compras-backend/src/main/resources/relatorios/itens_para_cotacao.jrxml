<?xml version="1.0" encoding="UTF-8"?>
<!-- Created with Jaspersoft Studio version 6.21.5.final using JasperReports Library version 6.21.5 -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="itens_para_cotacao" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">

    <!-- Estilos padronizados -->
    <style name="Title" forecolor="#1A237E" fontName="Arial" fontSize="24" isBold="true"/>
    <style name="SubTitle" forecolor="#3F51B5" fontName="Arial" fontSize="14" isBold="true"/>
    <style name="Header" forecolor="#FFFFFF" fontName="Arial" fontSize="11" isBold="true"/>
    <style name="Detail" fontName="Arial" fontSize="10"/>
    <style name="Footer" forecolor="#666666" fontName="Arial" fontSize="9"/>
    <style name="Row" mode="Opaque">
        <conditionalStyle>
            <conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
            <style backcolor="#F5F5F5"/>
        </conditionalStyle>
    </style>

    <!-- Parâmetros -->
    <parameter name="SOLICITACAO_ID" class="java.lang.Long"/>
    <parameter name="DATA_GERACAO" class="java.time.LocalDateTime"/>

    <!-- Campos -->
    <field name="id" class="java.lang.Long"/>
    <field name="nome" class="java.lang.String"/>
    <field name="descricao" class="java.lang.String"/>
    <field name="quantidade" class="java.lang.Integer"/>
    <field name="observacao" class="java.lang.String"/>
    <field name="solicitacaoId" class="java.lang.Long"/>

    <!-- Variável para contar itens -->
    <variable name="TOTAL_ITENS" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{id}]]></variableExpression>
    </variable>

    <!-- Cabeçalho do Relatório -->
    <title>
        <band height="150">
            <!-- Logo UEMA Centralizada -->
            <image scaleImage="RetainShape" hAlign="Center" vAlign="Top">
                <reportElement x="192" y="10" width="150" height="50"/>
                <imageExpression><![CDATA["relatorios/logo-uema-site.png"]]></imageExpression>
            </image>

            <!-- Nome do Relatório Centralizado -->
            <staticText>
                <reportElement style="Title" x="0" y="70" width="535" height="35"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[SOLICITAÇÃO DE COTAÇÃO]]></text>
            </staticText>

            <!-- Informações da Solicitação -->
            <staticText>
                <reportElement style="SubTitle" x="10" y="115" width="120" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="11"/>
                </textElement>
                <text><![CDATA[Solicitação Nº:]]></text>
            </staticText>

            <textField>
                <reportElement style="Detail" x="130" y="115" width="100" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{SOLICITACAO_ID}]]></textFieldExpression>
            </textField>

            <!-- Linha Separadora -->
            <line>
                <reportElement x="0" y="147" width="535" height="1" forecolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="2.0" lineStyle="Solid"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <!-- Cabeçalho de Página -->
    <pageHeader>
        <band height="30">
            <staticText>
                <reportElement style="SubTitle" x="0" y="5" width="535" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="12"/>
                </textElement>
                <text><![CDATA[Itens para Cotação]]></text>
            </staticText>
        </band>
    </pageHeader>

    <!-- Cabeçalho das Colunas -->
    <columnHeader>
        <band height="30">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="535" height="30" backcolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement style="Header" x="10" y="5" width="50" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="12"/>
                </textElement>
                <text><![CDATA[Nº]]></text>
            </staticText>

            <staticText>
                <reportElement style="Header" x="70" y="5" width="180" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="12"/>
                    <paragraph leftIndent="5"/>
                </textElement>
                <text><![CDATA[Nome do Item]]></text>
            </staticText>

            <staticText>
                <reportElement style="Header" x="260" y="5" width="195" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="12"/>
                    <paragraph leftIndent="5"/>
                </textElement>
                <text><![CDATA[Descrição]]></text>
            </staticText>

            <staticText>
                <reportElement style="Header" x="465" y="5" width="60" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="12"/>
                </textElement>
                <text><![CDATA[Qtd.]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Detalhes (Linhas de Dados) -->
    <detail>
        <band height="75">
            <elementGroup>
                <rectangle>
                    <reportElement style="Row" stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="75"/>
                    <graphicElement>
                        <pen lineWidth="0.5" lineColor="#E0E0E0"/>
                    </graphicElement>
                </rectangle>

                <!-- Número do Item -->
                <textField textAdjust="StretchHeight">
                    <reportElement style="Detail" x="10" y="8" width="50" height="18"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle">
                        <font size="11" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
                </textField>

                <!-- Nome do Item -->
                <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                    <reportElement style="Detail" x="70" y="8" width="180" height="18"/>
                    <textElement textAlignment="Left" verticalAlignment="Middle">
                        <font size="11" isBold="true"/>
                        <paragraph leftIndent="5"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{nome}]]></textFieldExpression>
                </textField>

                <!-- Descrição -->
                <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                    <reportElement style="Detail" x="260" y="8" width="195" height="55"/>
                    <textElement textAlignment="Left" verticalAlignment="Top">
                        <font size="10"/>
                        <paragraph leftIndent="5" lineSpacing="1_1_2"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{descricao}]]></textFieldExpression>
                </textField>

                <!-- Quantidade -->
                <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                    <reportElement style="Detail" x="465" y="8" width="60" height="18" forecolor="#1A237E"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle">
                        <font size="12" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{quantidade}]]></textFieldExpression>
                </textField>

                <!-- Observações -->
                <staticText>
                    <reportElement style="Detail" x="70" y="35" width="80" height="12" forecolor="#666666">
                        <printWhenExpression><![CDATA[$F{observacao} != null && !$F{observacao}.isEmpty()]]></printWhenExpression>
                    </reportElement>
                    <textElement textAlignment="Left" verticalAlignment="Top">
                        <font size="8" isBold="true"/>
                        <paragraph leftIndent="5"/>
                    </textElement>
                    <text><![CDATA[Observações:]]></text>
                </staticText>

                <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                    <reportElement style="Detail" x="70" y="47" width="180" height="20" forecolor="#555555">
                        <printWhenExpression><![CDATA[$F{observacao} != null && !$F{observacao}.isEmpty()]]></printWhenExpression>
                    </reportElement>
                    <textElement textAlignment="Left" verticalAlignment="Top">
                        <font size="9"/>
                        <paragraph leftIndent="5" lineSpacing="1_1_2"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{observacao}]]></textFieldExpression>
                </textField>
            </elementGroup>
        </band>
    </detail>

    <!-- Rodapé da Página -->
    <pageFooter>
        <band height="30">
            <line>
                <reportElement x="0" y="2" width="535" height="1" forecolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="1.0"/>
                </graphicElement>
            </line>

            <!-- Data e Hora de Geração -->
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement style="Footer" x="5" y="8" width="150" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>

            <!-- Sistema -->
            <staticText>
                <reportElement style="Footer" x="180" y="8" width="180" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Sistema de Gestão de Compras - UEMA]]></text>
            </staticText>

            <!-- Paginação -->
            <textField>
                <reportElement style="Footer" x="385" y="8" width="100" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>

            <textField evaluationTime="Report">
                <reportElement style="Footer" x="485" y="8" width="50" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[" de " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- Resumo -->
    <summary>
        <band height="60">
            <line>
                <reportElement x="0" y="10" width="535" height="2" forecolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="2.0"/>
                </graphicElement>
            </line>

            <!-- Total de Itens -->
            <rectangle>
                <reportElement mode="Opaque" x="10" y="22" width="200" height="30" backcolor="#F5F5F5"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#3F51B5"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement style="SubTitle" x="20" y="27" width="120" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Total de Itens:]]></text>
            </staticText>

            <textField>
                <reportElement style="Detail" x="140" y="27" width="60" height="20" forecolor="#1A237E"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_ITENS}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
