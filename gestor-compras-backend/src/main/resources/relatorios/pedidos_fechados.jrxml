<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="pedidos_fechados" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">

    <style name="Title" forecolor="#1A237E" fontName="SansSerif" fontSize="24" isBold="true"/>
    <style name="Header" forecolor="#FFFFFF" fontName="SansSerif" fontSize="10" isBold="true"/>
    <style name="Detail" fontName="SansSerif" fontSize="9"/>
    <style name="Footer" forecolor="#666666" fontName="SansSerif" fontSize="9"/>
    <style name="Row" mode="Opaque">
        <conditionalStyle>
            <conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
            <style backcolor="#F5F5F5"/>
        </conditionalStyle>
    </style>

    <field name="solicitacaoId" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>
    <field name="dataCriacao" class="java.time.LocalDateTime"/>
    <field name="quantidadeItens" class="java.lang.Integer"/>
    <field name="observacao" class="java.lang.String"/>
    <field name="itensResumidos" class="java.lang.String"/>

    <title>
        <band height="125">
            <image scaleImage="RetainShape" hAlign="Center" vAlign="Top">
                <reportElement x="192" y="10" width="150" height="50"/>
                <imageExpression><![CDATA["relatorios/logo-uema-site.png"]]></imageExpression>
            </image>
            <staticText>
                <reportElement style="Title" x="0" y="70" width="535" height="35"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[PEDIDOS FECHADOS]]></text>
            </staticText>
            <staticText>
                <reportElement style="Footer" x="420" y="108" width="115" height="12"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isItalic="true"/>
                </textElement>
                <text><![CDATA[Versão 1.0]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="122" width="535" height="1" forecolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="2.0"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="535" height="25" backcolor="#3F51B5"/>
            </rectangle>
            <staticText>
                <reportElement style="Header" x="5" y="2" width="40" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement style="Header" x="50" y="2" width="80" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <paragraph leftIndent="5"/>
                </textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
            <staticText>
                <reportElement style="Header" x="135" y="2" width="90" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Data Criação]]></text>
            </staticText>
            <staticText>
                <reportElement style="Header" x="230" y="2" width="50" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Qtd. Itens]]></text>
            </staticText>
            <staticText>
                <reportElement style="Header" x="285" y="2" width="245" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <paragraph leftIndent="5"/>
                </textElement>
                <text><![CDATA[Itens]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="35">
            <rectangle>
                <reportElement style="Row" x="0" y="0" width="535" height="35"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#E0E0E0"/>
                </graphicElement>
            </rectangle>
            <rectangle>
                <reportElement mode="Opaque" x="50" y="5" width="80" height="25" backcolor="#C8E6C9">
                    <printWhenExpression><![CDATA[$F{status}.equals("APROVADO")]]></printWhenExpression>
                </reportElement>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#4CAF50"/>
                </graphicElement>
            </rectangle>
            <rectangle>
                <reportElement mode="Opaque" x="50" y="5" width="80" height="25" backcolor="#FFCDD2">
                    <printWhenExpression><![CDATA[$F{status}.equals("CANCELADO")]]></printWhenExpression>
                </reportElement>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#F44336"/>
                </graphicElement>
            </rectangle>
            <textField>
                <reportElement style="Detail" x="5" y="5" width="40" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Top">
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{solicitacaoId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement style="Detail" x="50" y="5" width="80" height="25"/>
                <textElement textAlignment="Left" verticalAlignment="Top">
                    <font isBold="true"/>
                    <paragraph leftIndent="5"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement style="Detail" x="135" y="5" width="90" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Top"/>
                <textFieldExpression><![CDATA[$F{dataCriacao}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement style="Detail" x="230" y="5" width="50" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Top"/>
                <textFieldExpression><![CDATA[$F{quantidadeItens}]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                <reportElement style="Detail" x="285" y="5" width="245" height="25"/>
                <textElement textAlignment="Left" verticalAlignment="Top">
                    <paragraph leftIndent="5"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{itensResumidos}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="30">
            <line>
                <reportElement x="0" y="2" width="535" height="1" forecolor="#3F51B5"/>
                <graphicElement>
                    <pen lineWidth="1.0"/>
                </graphicElement>
            </line>
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement style="Footer" x="5" y="8" width="150" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement style="Footer" x="180" y="8" width="180" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Sistema de Gestão de Compras - UEMA]]></text>
            </staticText>
            <textField>
                <reportElement style="Footer" x="385" y="8" width="100" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report">
                <reportElement style="Footer" x="485" y="8" width="50" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[" de " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>
